<!doctype html>
<html lang="pl">
<%- include('../../partials/head') %>
<body class="bg-surface text-on-surface font-body antialiased min-h-screen flex flex-col">
<%- include('../../partials/header', { showBack: true, headerTitle: 'Odzyskaj hasło', showAuth: false }) %>

<main class="flex-1 flex flex-col items-center justify-center px-6 pt-24 pb-12">
  <div class="w-full max-w-md">
    <div class="text-center mb-10">
      <div class="inline-flex items-center justify-center w-20 h-20 rounded-xl bg-surface-container-low mb-6">
        <span class="material-symbols-outlined text-primary text-4xl">mail</span>
      </div>
      <% if (sent) { %>
        <h1 class="font-headline text-3xl font-extrabold text-on-surface mb-3 tracking-tight">Sprawdź e-mail</h1>
        <p class="text-on-surface-variant leading-relaxed">Jeśli konto z tym adresem istnieje, wysłaliśmy link do zmiany hasła. Sprawdź też folder spam.</p>
      <% } else { %>
        <h1 class="font-headline text-3xl font-extrabold text-on-surface mb-3 tracking-tight">Zapomniałeś hasła?</h1>
        <p class="text-on-surface-variant leading-relaxed">Podaj adres e-mail powiązany z Twoim kontem, a wyślemy link do zmiany hasła.</p>
      <% } %>
    </div>

    <% if (!sent) { %>
      <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0_12px_32px_rgba(0,55,73,0.06)] border border-outline-variant/10">
        <% if (errors && errors.length) { %>
          <div class="flex items-start gap-2 bg-error-container/10 p-3 rounded-lg border border-error/10 mb-6">
            <span class="material-symbols-outlined text-error text-sm mt-0.5">error</span>
            <div>
              <% errors.forEach(function(err) { %>
                <p class="text-xs text-error font-medium"><%= err %></p>
              <% }); %>
            </div>
          </div>
        <% } %>

        <form method="post" action="/forgot-password" class="space-y-6">
          <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>" />

          <div class="space-y-2">
            <label class="block font-label text-sm font-semibold text-on-surface-variant ml-1" for="email">Adres e-mail</label>
            <input class="w-full bg-surface-container-low border-none rounded-lg py-4 px-4 focus:ring-2 focus:ring-primary transition-all text-on-surface placeholder:text-outline/50" id="email" name="email" placeholder="jan@example.pl" type="email" value="<%= formData.email || '' %>" />
          </div>

          <button class="w-full signature-gradient text-on-primary font-headline font-bold py-4 rounded-lg shadow-md hover:brightness-110 active:scale-95 transition-all duration-150" type="submit">
            Wyślij link
          </button>
        </form>
      </div>
    <% } %>

    <div class="mt-8 text-center">
      <a class="text-sm text-on-surface-variant font-medium hover:text-primary" href="/login">Wróć do logowania</a>
    </div>
  </div>
</main>
</body>
</html>
