<!doctype html>
<html lang="pl">
<%- include('../../partials/head') %>
<body class="bg-surface text-on-surface font-body antialiased min-h-screen flex flex-col">
<%- include('../../partials/header', { showBack: false, headerTitle: 'dlaczegozyc.pl', showAuth: false }) %>

<main class="flex-1 flex flex-col items-center justify-center px-6 pt-24 pb-12">
  <div class="w-full max-w-md flex flex-col items-center text-center">
    <div class="w-24 h-24 bg-error-container/20 rounded-full flex items-center justify-center mb-8">
      <span class="material-symbols-outlined text-error text-5xl">link_off</span>
    </div>

    <h1 class="font-headline font-bold text-2xl mb-4 text-on-surface tracking-tight">
      Link wygasł lub jest nieprawidłowy
    </h1>
    <p class="text-on-surface-variant leading-relaxed mb-10 px-2">
      Ten link do resetu hasła nie jest już aktywny. Możesz wygenerować nowy link.
    </p>

    <div class="w-full space-y-4">
      <a href="/forgot-password" class="w-full h-14 signature-gradient text-on-primary font-body font-semibold rounded-xl shadow-lg active:scale-95 transition-all duration-150 flex items-center justify-center gap-2">
        <span class="material-symbols-outlined">mail</span>
        Wyślij nowy link
      </a>
      <a href="/login" class="w-full h-14 bg-surface-container-lowest text-on-surface font-body font-semibold rounded-xl border border-outline/20 active:scale-95 transition-all duration-150 flex items-center justify-center">
        Wróć do logowania
      </a>
    </div>
  </div>
</main>
</body>
</html>
