<!doctype html>
<html lang="pl">
<%- include('../../partials/head') %>
<body class="bg-surface text-on-surface font-body antialiased min-h-screen flex flex-col">
<%- include('../../partials/header', { showBack: true, headerTitle: 'Zaloguj się', showAuth: false }) %>

<main class="flex-1 flex flex-col items-center justify-center px-6 pt-24 pb-12">
  <div class="w-full max-w-md mb-12 text-center">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-xl bg-surface-container-low mb-6">
      <span class="material-symbols-outlined text-primary text-4xl">lock_open</span>
    </div>
    <h1 class="font-headline text-3xl font-extrabold text-on-surface mb-3 tracking-tight">Witaj ponownie</h1>
    <p class="text-on-surface-variant leading-relaxed">Znajdź chwilę spokoju i kontynuuj swoją podróż.</p>
  </div>

  <div class="w-full max-w-md bg-surface-container-lowest rounded-xl p-8 shadow-[0_12px_32px_rgba(0,55,73,0.06)] border border-outline-variant/10">
    <% if (success) { %>
      <div class="flex items-start gap-2 bg-tertiary-container/30 p-3 rounded-lg border border-primary/10 mb-6">
        <span class="material-symbols-outlined text-primary text-sm mt-0.5">check_circle</span>
        <p class="text-xs text-on-primary-container font-medium"><%= success %></p>
      </div>
    <% } %>

    <% if (errors && errors.length) { %>
      <div class="flex items-start gap-2 bg-error-container/10 p-3 rounded-lg border border-error/10 mb-6">
        <span class="material-symbols-outlined text-error text-sm mt-0.5">error</span>
        <div>
          <% errors.forEach(function(err) { %>
            <p class="text-xs text-error font-medium"><%= err %></p>
          <% }); %>
        </div>
      </div>
    <% } %>

    <form method="post" action="/login" class="space-y-6">
      <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>" />

      <div class="space-y-2">
        <label class="block font-label text-sm font-semibold text-on-surface-variant ml-1" for="login">Login</label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline-variant text-xl">person</span>
          <input class="w-full pl-12 pr-4 py-4 bg-surface-container-low border-none rounded-lg focus:ring-2 focus:ring-primary transition-all text-on-surface placeholder:text-outline/50" id="login" name="login" placeholder="Twój login" type="text" value="<%= formData.login || '' %>" />
        </div>
      </div>

      <div class="space-y-2">
        <label class="block font-label text-sm font-semibold text-on-surface-variant ml-1" for="password">Hasło</label>
        <div class="relative">
          <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline-variant text-xl">key</span>
          <input class="w-full pl-12 pr-4 py-4 bg-surface-container-low border-none rounded-lg focus:ring-2 focus:ring-primary transition-all text-on-surface placeholder:text-outline/50" id="password" name="password" placeholder="••••••••" type="password" />
        </div>
      </div>

      <div class="flex justify-end">
        <a class="text-sm font-medium text-outline hover:text-primary transition-colors px-1" href="/forgot-password">Zapomniałeś hasła?</a>
      </div>

      <button class="w-full signature-gradient text-on-primary font-headline font-bold py-4 rounded-lg shadow-md hover:brightness-110 active:scale-95 transition-all duration-150" type="submit">
        Zaloguj się
      </button>
    </form>
  </div>

  <div class="mt-10 text-center">
    <p class="text-on-surface-variant text-sm">
      Nie masz konta?
      <a class="text-primary font-bold hover:underline ml-1" href="/register">Załóż je tutaj.</a>
    </p>
  </div>
</main>
</body>
</html>
