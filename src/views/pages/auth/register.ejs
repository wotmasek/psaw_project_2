<!doctype html>
<html lang="pl">
<%- include('../../partials/head') %>
<body class="bg-surface text-on-surface font-body antialiased min-h-screen flex flex-col">
<%- include('../../partials/header', { showBack: true, headerTitle: 'dlaczegozyc.pl', showAuth: false }) %>

<main class="flex-1 pt-24 pb-12 px-6 flex flex-col items-center max-w-md mx-auto w-full">
  <section class="w-full mb-10 text-left">
    <h1 class="font-headline font-extrabold text-3xl text-on-surface tracking-tight mb-4">
      Rozpocznij swoją <span class="text-primary">podróż</span>
    </h1>
    <p class="text-on-surface-variant leading-relaxed opacity-90">
      Twoje konto pomaga śledzić Twoje wpisy i inspiracje.
    </p>
  </section>

  <div class="w-full bg-surface-container-lowest rounded-xl p-8 shadow-[0_12px_32px_rgba(0,55,73,0.04)]">
    <% if (errors && errors.length) { %>
      <div class="flex items-start gap-2 bg-error-container/10 p-3 rounded-lg border border-error/10 mb-6">
        <span class="material-symbols-outlined text-error text-sm mt-0.5">error</span>
        <div>
          <% errors.forEach(function(err) { %>
            <p class="text-xs text-error font-medium"><%= err %></p>
          <% }); %>
        </div>
      </div>
    <% } %>

    <form method="post" action="/register" class="space-y-6">
      <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>" />

      <div class="space-y-2">
        <label class="block text-sm font-semibold text-on-surface-variant ml-1" for="login">Login</label>
        <input class="w-full bg-surface-container-low border-0 ring-1 ring-outline-variant/20 focus:ring-2 focus:ring-primary rounded-lg py-3.5 px-4 text-on-surface transition-all placeholder:text-outline/50 outline-none" id="login" name="login" placeholder="twoj-login" type="text" value="<%= formData.login || '' %>" />
      </div>

      <div class="space-y-2">
        <label class="block text-sm font-semibold text-on-surface-variant ml-1" for="password">Hasło</label>
        <input class="w-full bg-surface-container-low border-0 ring-1 ring-outline-variant/20 focus:ring-2 focus:ring-primary rounded-lg py-3.5 px-4 text-on-surface transition-all placeholder:text-outline/50 outline-none" id="password" name="password" placeholder="min. 6 znaków" type="password" />
      </div>

      <div class="space-y-2">
        <label class="block text-sm font-semibold text-on-surface-variant ml-1" for="passwordConfirmation">Potwierdź hasło</label>
        <input class="w-full bg-surface-container-low border-0 ring-1 ring-outline-variant/20 focus:ring-2 focus:ring-primary rounded-lg py-3.5 px-4 text-on-surface transition-all placeholder:text-outline/50 outline-none" id="passwordConfirmation" name="passwordConfirmation" placeholder="••••••••" type="password" />
      </div>

      <button class="w-full signature-gradient text-on-primary font-bold py-4 rounded-lg shadow-lg shadow-primary/20 hover:scale-[1.02] active:scale-95 transition-all duration-300 mt-4" type="submit">
        Załóż konto
      </button>
    </form>
  </div>

  <div class="mt-8 text-center">
    <p class="text-sm text-on-surface-variant font-medium">
      Masz już konto? <a class="text-primary font-bold hover:underline decoration-2 underline-offset-4" href="/login">Zaloguj się</a>
    </p>
  </div>
</main>
</body>
</html>
