<!doctype html>
<html lang="pl">
<%- include('../../partials/head') %>
<body class="bg-surface text-on-surface font-body antialiased min-h-screen flex flex-col">
<%- include('../../partials/header', { showBack: true, headerTitle: 'dlaczegozyc.pl' }) %>

<main class="flex-grow flex flex-col items-center justify-center px-8 pt-16 pb-24 text-center">
  <div class="relative w-full max-w-xs aspect-square mb-12 flex items-center justify-center">
    <div class="absolute inset-0 bg-surface-container-low rounded-full blur-3xl opacity-60 scale-110"></div>
    <div class="relative z-10 w-64 h-64 bg-surface-container-lowest rounded-[2.5rem] shadow-[0_12px_32px_rgba(0,55,73,0.06)] flex flex-col items-center justify-center p-8">
      <div class="w-24 h-24 bg-surface-container flex items-center justify-center rounded-full mb-6">
        <span class="material-symbols-outlined text-outline text-5xl" style="font-variation-settings: 'wght' 300;">cloud_off</span>
      </div>
      <div class="space-y-2">
        <div class="h-2 w-32 bg-surface-container-high rounded-full mx-auto"></div>
        <div class="h-2 w-24 bg-surface-container-low rounded-full mx-auto"></div>
      </div>
    </div>
  </div>

  <div class="max-w-md">
    <h1 class="font-headline font-extrabold text-2xl mb-4 tracking-tight text-on-surface">Chwila wytchnienia...</h1>
    <p class="font-body text-on-surface-variant leading-relaxed text-lg mb-10">
      <%= locals.message || 'Przepraszamy, coś poszło nie tak. Spokojnie, zaraz znajdziemy właściwą drogę.' %>
    </p>
  </div>

  <div class="w-full max-w-sm space-y-4">
    <a href="/" class="block w-full py-4 px-6 bg-gradient-to-br from-primary to-primary-container text-on-primary font-headline font-bold rounded-xl shadow-lg hover:brightness-110 active:scale-95 transition-all duration-300 text-center">
      Powrót do bezpiecznego miejsca
    </a>
  </div>
</main>

<%- include('../../partials/navigation-public') %>
</body>
</html>
