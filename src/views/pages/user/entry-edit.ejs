<!doctype html>
<html lang="pl">
<%- include('../../partials/head') %>
<body class="bg-surface text-on-surface font-body antialiased min-h-screen flex flex-col">
<%- include('../../partials/header', { showBack: true, headerTitle: 'Edycja wpisu', showAuth: false }) %>

<main class="flex-1 pt-24 pb-12 px-6 max-w-md mx-auto w-full">
  <div class="bg-surface-container-lowest rounded-xl p-8 shadow-[0_12px_32px_rgba(0,55,73,0.04)] border border-outline-variant/10">
    <% if (errors && errors.length) { %>
      <div class="flex items-start gap-2 bg-error-container/10 p-3 rounded-lg border border-error/10 mb-6">
        <span class="material-symbols-outlined text-error text-sm mt-0.5">error</span>
        <div>
          <% errors.forEach(function(err) { %>
            <p class="text-xs text-error font-medium"><%= err %></p>
          <% }); %>
        </div>
      </div>
    <% } %>

    <form method="post" action="/entries/<%= entry.id %>" class="space-y-6">
      <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>" />

      <div class="space-y-2">
        <label class="block text-sm font-semibold text-on-surface-variant ml-1" for="title">Tytuł</label>
        <input class="w-full bg-surface-container-low border-none rounded-lg py-3.5 px-4 focus:ring-2 focus:ring-primary transition-all text-on-surface placeholder:text-outline/50" id="title" name="title" type="text" value="<%= entry.title %>" />
      </div>

      <div class="space-y-2">
        <label class="block text-sm font-semibold text-on-surface-variant ml-1" for="body">Treść</label>
        <textarea class="w-full bg-surface-container-low border-none rounded-lg py-3.5 px-4 focus:ring-2 focus:ring-primary transition-all text-on-surface placeholder:text-outline/50 min-h-[200px] resize-y" id="body" name="body"><%= entry.body %></textarea>
      </div>

      <button class="w-full signature-gradient text-on-primary font-headline font-bold py-4 rounded-lg shadow-md hover:brightness-110 active:scale-95 transition-all duration-150" type="submit">
        Zapisz zmiany
      </button>
    </form>
  </div>

  <div class="mt-4 text-center">
    <a href="/my-entries" class="text-sm text-on-surface-variant font-medium hover:text-primary">Wróć do listy wpisów</a>
  </div>
</main>
</body>
</html>
