<!doctype html>
<html lang="pl">
<%- include('../../partials/head') %>
<body class="bg-surface text-on-surface font-body antialiased min-h-screen pb-16">
<%- include('../../partials/header', { showBack: true, headerTitle: 'Wiadomość', showAuth: false }) %>

<main class="pt-24 pb-16 px-6 max-w-md lg:max-w-2xl mx-auto space-y-6">
  <div class="bg-surface-container-lowest rounded-xl p-6 shadow-sm">
    <div class="flex items-center gap-3 mb-4">
      <div class="w-10 h-10 rounded-lg bg-surface-container-high flex items-center justify-center text-outline">
        <span class="material-symbols-outlined">visibility_off</span>
      </div>
      <div>
        <p class="font-bold text-on-surface text-sm">Anonimowa wiadomość</p>
        <p class="text-[10px] text-outline"><%= new Date(message.created_at).toLocaleString('pl-PL', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
      </div>
    </div>
    <span class="text-[10px] font-bold uppercase px-2 py-0.5 rounded-full mb-4 inline-block <%= message.status === 'new' ? 'bg-primary-container text-on-primary-container' : message.status === 'reviewed' ? 'bg-tertiary-container text-on-tertiary-container' : 'bg-surface-container-high text-on-surface-variant' %>"><%= message.status === 'new' ? 'nowa' : message.status === 'reviewed' ? 'przeczytana' : 'archiwum' %></span>
    <p class="text-on-surface text-sm leading-relaxed whitespace-pre-wrap"><%= message.body %></p>
  </div>

  <div class="grid grid-cols-3 gap-2">
    <% if (message.status !== 'new') { %>
      <form method="post" action="/admin/messages/<%= message.id %>/status">
        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>" />
        <input type="hidden" name="status" value="new" />
        <button type="submit" class="w-full py-3 bg-surface-container-low rounded-lg text-xs font-bold text-on-surface-variant hover:bg-surface-container transition-colors">Nowa</button>
      </form>
    <% } %>
    <% if (message.status !== 'reviewed') { %>
      <form method="post" action="/admin/messages/<%= message.id %>/status">
        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>" />
        <input type="hidden" name="status" value="reviewed" />
        <button type="submit" class="w-full py-3 bg-tertiary-container/30 rounded-lg text-xs font-bold text-tertiary hover:bg-tertiary-container transition-colors">Przeczytana</button>
      </form>
    <% } %>
    <% if (message.status !== 'archived') { %>
      <form method="post" action="/admin/messages/<%= message.id %>/status">
        <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>" />
        <input type="hidden" name="status" value="archived" />
        <button type="submit" class="w-full py-3 bg-surface-container-high rounded-lg text-xs font-bold text-on-surface-variant hover:bg-surface-container-highest transition-colors">Archiwum</button>
      </form>
    <% } %>
  </div>

  <form method="post" action="/admin/messages/<%= message.id %>/delete" onsubmit="return confirm('Usunąć wiadomość na stałe?')">
    <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>" />
    <button class="w-full flex items-center justify-center gap-2 py-3 rounded-xl text-error font-bold hover:bg-error-container/10 transition-colors border border-error/20" type="submit">
      <span class="material-symbols-outlined">delete</span> Usuń trwale
    </button>
  </form>

  <a href="/admin/messages" class="block text-center text-primary text-sm font-semibold mt-2">
    <span class="material-symbols-outlined align-middle text-sm mr-1">arrow_back</span>Wróć do listy
  </a>
</main>
</body>
</html>
