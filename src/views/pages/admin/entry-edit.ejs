<!doctype html>
<html lang="pl">
<%- include('../../partials/head') %>
<body class="bg-surface text-on-surface font-body antialiased min-h-screen flex flex-col">
<%- include('../../partials/header', { showBack: true, headerTitle: 'Edycja wpisu', showAuth: false }) %>

<main class="flex-1 pt-24 pb-12 px-6 max-w-md mx-auto w-full">
  <div class="bg-surface-container-lowest rounded-xl p-6 shadow-sm border border-outline-variant/10">
    <% if (errors && errors.length) { %>
      <div class="flex items-start gap-2 bg-error-container/10 p-3 rounded-lg border border-error/10 mb-6">
        <span class="material-symbols-outlined text-error text-sm mt-0.5">error</span>
        <div><% errors.forEach(function(err) { %><p class="text-xs text-error font-medium"><%= err %></p><% }); %></div>
      </div>
    <% } %>

    <form method="post" action="/admin/entries/<%= entry.id %>" class="space-y-5">
      <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>" />

      <div class="space-y-2">
        <label class="block text-sm font-semibold text-on-surface-variant ml-1" for="title">Tytuł</label>
        <input class="w-full bg-surface-container-low border-none rounded-lg py-3 px-4 focus:ring-2 focus:ring-primary transition-all text-on-surface" id="title" name="title" type="text" value="<%= entry.title || '' %>" />
      </div>

      <div class="space-y-2">
        <label class="block text-sm font-semibold text-on-surface-variant ml-1" for="body">Treść</label>
        <textarea class="w-full bg-surface-container-low border-none rounded-lg py-3 px-4 focus:ring-2 focus:ring-primary transition-all text-on-surface min-h-[150px] resize-y" id="body" name="body"><%= entry.body || '' %></textarea>
      </div>

      <div class="space-y-2">
        <label class="block text-sm font-semibold text-on-surface-variant ml-1" for="status">Status</label>
        <select class="w-full bg-surface-container-low border-none rounded-lg py-3 px-4 focus:ring-2 focus:ring-primary transition-all text-on-surface" id="status" name="status">
          <% statuses.forEach(function(s) { %>
            <option value="<%= s %>" <%= entry.status === s ? 'selected' : '' %>><%= s %></option>
          <% }); %>
        </select>
      </div>

      <button class="w-full signature-gradient text-on-primary font-headline font-bold py-4 rounded-lg shadow-md hover:brightness-110 active:scale-95 transition-all duration-150" type="submit">
        Zapisz zmiany
      </button>
    </form>
  </div>

  <div class="mt-6">
    <form method="post" action="/admin/entries/<%= entry.id %>/delete" onsubmit="return confirm('Usunąć wpis na stałe?')">
      <input type="hidden" name="_csrf" value="<%= locals.csrfToken || '' %>" />
      <button class="w-full flex items-center justify-center gap-2 py-3 rounded-xl text-error font-bold hover:bg-error-container/10 transition-colors border border-error/20" type="submit">
        <span class="material-symbols-outlined">delete</span> Usuń wpis
      </button>
    </form>
  </div>
</main>
</body>
</html>
