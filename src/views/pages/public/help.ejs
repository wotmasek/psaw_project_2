<!doctype html>
<html lang="pl">
<%- include('../../partials/head') %>
<body class="bg-surface text-on-surface font-body antialiased min-h-screen flex flex-col">
<%- include('../../partials/header', { headerTitle: 'Centrum Pomocy' }) %>

<main class="flex-1 pt-24 pb-32 px-6 max-w-md mx-auto w-full">
  <section class="mb-10">
    <div class="bg-gradient-to-br from-primary to-primary-container p-6 rounded-xl shadow-[0_12px_32px_rgba(0,55,73,0.06)] text-on-primary">
      <div class="flex items-center gap-3 mb-4">
        <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">emergency_home</span>
        <h2 class="text-xl font-headline font-bold">Potrzebujesz pilnej pomocy?</h2>
      </div>
      <p class="text-on-primary/90 mb-6 leading-relaxed font-body">Jeśli Ty lub ktoś bliski znajduje się w bezpośrednim niebezpieczeństwie, zadzwoń pod numer alarmowy.</p>
      <div class="space-y-3">
        <a class="flex items-center justify-between bg-surface-container-lowest text-on-surface p-4 rounded-lg font-bold text-lg hover:bg-surface-bright transition-colors" href="tel:112">
          <span>Numer alarmowy: 112</span>
          <span class="material-symbols-outlined">call</span>
        </a>
        <a class="flex items-center justify-between bg-surface-container-lowest text-on-surface p-4 rounded-lg font-bold text-lg hover:bg-surface-bright transition-colors" href="tel:116123">
          <span>Kryzysowy: 116 123</span>
          <span class="material-symbols-outlined">support_agent</span>
        </a>
      </div>
    </div>
  </section>

  <% if (locals.helpSections && helpSections.length > 0) { %>
    <section class="space-y-6">
      <h3 class="text-sm font-label font-semibold text-outline tracking-widest uppercase">Kategorie pomocy</h3>

      <%
        const grouped = {};
        helpSections.forEach(function(s) {
          if (!grouped[s.category]) grouped[s.category] = [];
          grouped[s.category].push(s);
        });
        const categoryIcons = { telefony: 'phone_in_talk', osrodki: 'distance', edukacja: 'menu_book' };
        const categoryColors = { telefony: 'bg-surface-container text-primary', osrodki: 'bg-tertiary-container text-tertiary', edukacja: 'bg-surface-container-high text-on-surface-variant' };
      %>

      <% Object.keys(grouped).forEach(function(cat) { %>
        <div class="bg-surface-container-lowest p-5 rounded-xl border border-outline-variant/20">
          <div class="flex items-start gap-4 mb-4">
            <div class="<%= categoryColors[cat] || 'bg-surface-container text-primary' %> p-3 rounded-lg">
              <span class="material-symbols-outlined"><%= categoryIcons[cat] || 'help' %></span>
            </div>
            <div>
              <h4 class="font-headline font-bold text-on-surface"><%= grouped[cat][0].title %></h4>
              <p class="text-sm text-on-surface-variant font-body"><%= grouped[cat][0].body %></p>
            </div>
          </div>
          <% if (grouped[cat].length > 1) { %>
            <ul class="space-y-4">
              <% grouped[cat].slice(1).forEach(function(item) { %>
                <li class="pl-4 border-l-2 border-primary-container">
                  <p class="font-bold text-sm"><%= item.title %></p>
                  <p class="text-sm text-outline"><%= item.body %></p>
                </li>
              <% }); %>
            </ul>
          <% } %>
        </div>
      <% }); %>
    </section>
  <% } else { %>
    <%- include('../../partials/empty-state', { emptyIcon: 'help', emptyTitle: 'Sekcja pomocy', emptyMessage: 'Informacje pomocowe pojawią się wkrótce.' }) %>
  <% } %>

  <div class="mt-10 text-center">
    <a href="/anonymous-box" class="inline-flex items-center gap-2 text-primary font-semibold hover:underline">
      <span class="material-symbols-outlined text-sm">inventory_2</span>
      Chcesz się podzielić? Napisz anonimowo
    </a>
  </div>

  <footer class="mt-12 mb-8 text-center px-4">
    <p class="text-xs text-outline leading-relaxed font-body">
      Wszystkie podane numery telefonów są bezpłatne na terenie Polski.<br />
      Twoje bezpieczeństwo jest dla nas najważniejsze.
    </p>
  </footer>
</main>

<%- include('../../partials/navigation-public') %>
</body>
</html>
