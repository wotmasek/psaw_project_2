<!doctype html>
<html lang="pl">
<%- include('../../partials/head') %>
<body class="bg-surface text-on-surface font-body antialiased min-h-screen flex flex-col">
<%- include('../../partials/header', { headerTitle: 'dlaczegozyc.pl' }) %>

<main class="flex-1 pt-24 pb-32 px-6 max-w-md mx-auto w-full">
  <header class="mb-10 text-left">
    <h2 class="font-headline text-3xl font-extrabold tracking-tight text-on-surface mb-3">Twoja Chwila</h2>
    <p class="text-on-surface-variant leading-relaxed opacity-80">Odpowiedz na kilka pytań, abyśmy mogli przygotować dla Ciebie coś, co przyniesie spokój i inspirację.</p>
  </header>

  <% if (locals.result) { %>
    <div class="mb-10">
      <article class="bg-surface-container-lowest rounded-3xl p-6 shadow-[0_12px_32px_rgba(0,55,73,0.06)]">
        <div class="flex items-start gap-4 mb-4">
          <div class="w-12 h-12 rounded-2xl bg-tertiary-container flex items-center justify-center shrink-0">
            <span class="material-symbols-outlined text-tertiary" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
          </div>
          <div>
            <h3 class="font-headline font-bold text-on-surface mb-1">Twoja inspiracja</h3>
            <p class="text-on-surface-variant leading-relaxed"><%= result.content %></p>
          </div>
        </div>
      </article>
      <div class="mt-6 text-center">
        <a href="/inspirations" class="text-primary font-semibold text-sm hover:underline">Zobacz wszystkie inspiracje</a>
      </div>
    </div>
  <% } %>

  <form method="POST" action="/inspirations/generator" class="space-y-10">
    <section class="space-y-4">
      <label class="block font-headline text-lg font-bold text-on-surface">Jak się dziś czujesz?</label>
      <div class="grid grid-cols-2 gap-3">
        <button type="submit" name="mood" value="calm" class="flex flex-col items-center justify-center p-4 rounded-xl bg-surface-container-lowest border border-outline-variant/10 hover:bg-primary-container transition-all active:scale-95 duration-150">
          <span class="material-symbols-outlined text-primary mb-2">sentiment_satisfied</span>
          <span class="font-label text-sm font-medium">Spokojnie</span>
        </button>
        <button type="submit" name="mood" value="hard" class="flex flex-col items-center justify-center p-4 rounded-xl bg-surface-container-lowest border border-outline-variant/10 hover:bg-primary-container transition-all active:scale-95 duration-150">
          <span class="material-symbols-outlined text-primary mb-2">sentiment_dissatisfied</span>
          <span class="font-label text-sm font-medium">Trudno</span>
        </button>
        <button type="submit" name="mood" value="energetic" class="flex flex-col items-center justify-center p-4 rounded-xl bg-surface-container-lowest border border-outline-variant/10 hover:bg-primary-container transition-all active:scale-95 duration-150">
          <span class="material-symbols-outlined text-primary mb-2">bolt</span>
          <span class="font-label text-sm font-medium">Energicznie</span>
        </button>
        <button type="submit" name="mood" value="tired" class="flex flex-col items-center justify-center p-4 rounded-xl bg-surface-container-lowest border border-outline-variant/10 hover:bg-primary-container transition-all active:scale-95 duration-150">
          <span class="material-symbols-outlined text-primary mb-2">bedtime</span>
          <span class="font-label text-sm font-medium">Zmęczenie</span>
        </button>
      </div>
    </section>

    <p class="text-center text-outline text-xs">Twoje odpowiedzi są prywatne i bezpieczne.</p>
  </form>

  <% if (locals.lastInspiration) { %>
    <div class="mt-16 pb-12">
      <div class="bg-surface-container-lowest p-6 rounded-2xl flex items-start gap-4 shadow-sm">
        <div class="p-3 bg-tertiary-container rounded-lg">
          <span class="material-symbols-outlined text-tertiary">auto_awesome</span>
        </div>
        <div>
          <h3 class="font-headline font-bold text-on-surface mb-1">Ostatnia inspiracja</h3>
          <p class="text-sm italic text-on-surface-variant">"<%= lastInspiration.content %>"</p>
        </div>
      </div>
    </div>
  <% } %>
</main>

<%- include('../../partials/navigation-public') %>
</body>
</html>
