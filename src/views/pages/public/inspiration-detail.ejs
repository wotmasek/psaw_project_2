<!doctype html>
<html lang="pl">
<%- include('../../partials/head') %>
<body class="bg-surface text-on-surface font-body antialiased min-h-screen flex flex-col">
<%- include('../../partials/header', { headerTitle: 'Inspiracja' }) %>

<main class="flex-1 pt-24 pb-32 px-6 max-w-md mx-auto w-full flex flex-col items-center">
  <article class="w-full space-y-8">
    <div class="flex flex-col space-y-1">
      <p class="text-outline uppercase tracking-widest text-[10px] font-semibold">Twoja dzisiejsza myśl</p>
      <p class="text-on-surface-variant font-medium text-sm">
        <%= new Date(inspiration.created_at).toLocaleDateString('pl-PL', { day: 'numeric', month: 'long', year: 'numeric' }) %>
      </p>
    </div>

    <div class="relative">
      <div class="absolute -left-4 top-0 w-1 h-12 bg-primary rounded-full opacity-20"></div>
      <h2 class="font-headline text-3xl font-extrabold text-on-surface leading-[1.2] tracking-tight">
        <%= inspiration.content %>
      </h2>
    </div>

    <% if (inspiration.title) { %>
      <div class="bg-surface-container-low rounded-2xl p-6">
        <p class="text-on-surface-variant leading-relaxed italic">
          <%= inspiration.title %>
        </p>
      </div>
    <% } %>
  </article>

  <div class="mt-16 w-full max-w-sm space-y-4">
    <a href="/inspirations" class="w-full py-4 px-8 rounded-xl border border-outline/20 flex items-center justify-center gap-3 text-outline font-medium hover:bg-surface-container-low transition-colors duration-300">
      <span class="material-symbols-outlined">arrow_back</span>
      Wróć do inspiracji
    </a>
  </div>
</main>

<%- include('../../partials/navigation-public') %>
</body>
</html>
