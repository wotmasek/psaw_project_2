# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Session/Auth
# -----------------------------------------------------------------------------
SESSION_SECRET=replace-with-long-random-secret
SESSION_COOKIE_NAME=dlaczegozyc.sid
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax

# -----------------------------------------------------------------------------
# Bootstrap admin/root account (seed/init only)
# -----------------------------------------------------------------------------
ADMIN_SEED_LOGIN=admin
ADMIN_SEED_PASSWORD=change-me-admin-password
ADMIN_SEED_IS_ACTIVE=true

# -----------------------------------------------------------------------------
# PostgreSQL (host runtime)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=dlaczegozyc
POSTGRES_USER=dlaczegozyc_app
POSTGRES_PASSWORD=change-me-postgres-password

# Full connection string used by the app
DATABASE_URL=postgresql://dlaczegozyc_app:change-me-postgres-password@localhost:5432/dlaczegozyc

# -----------------------------------------------------------------------------
# SMTP (used for password reset emails)
# For local dev, use Mailpit (see docker-compose.yml): host=localhost, port=1025
# For production, use a real SMTP provider.
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=dlaczegozyc.pl
SMTP_FROM_EMAIL=noreply@dlaczegozyc.pl

# -----------------------------------------------------------------------------
# Security and limits
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BODY_LIMIT=100kb
TRUST_PROXY=false

